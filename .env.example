# Local server
# --- Render.com: הקובץ .env לא בגיט. אחרי git push חייבים להעתיק ל-Environment ב-Render:
# OPENAI_API_KEY, TELEGRAM_BOT_TOKEN (לטלגרם), ולוודא TELEGRAM_MISSILE_AI=1 אם רוצים טילים מוקדמים מ-AI.
# השוואה למחשב: פתחו https://YOUR-APP.onrender.com/health ושדה deployment (ללא חשיפת מפתחות).
HOST=127.0.0.1
PORT=8080

# Oref / Pikud HaOref
OREF_URL=https://www.oref.org.il/warningMessages/alert/alerts.json
OREF_REFERER=https://www.oref.org.il/
# Timeout בבקשה ל-alerts.json (מונע תקיעה כשפיקוד איטי). טווח: 1500–60000 ms
OREF_TIMEOUT_MS=4500
# מרווח poll לפיקוד (מינ׳ 2s). כשהתשובה תקינה ההתנהגות כמו קודם; גיבוי TZOFAR רק בכשל בקשה/JSON
OREF_POLL_MS=3000
# פיד אירועים (עמודה "פיד אירועים"): נשמר בשרת ב־data/client-event-feed.json (עד ~12 שעות + מגבלת שורות). HTTP: GET /api/feed/events
# CLIENT_EVENT_FEED_RETENTION_HOURS=12
# CLIENT_EVENT_FEED_MAX=1500
# מאחורי פרוקסי (Render): כמה X-Forwarded-For hops לסמוך עליהם — ל־req.ip ומגבלת קצב
# TRUST_PROXY_HOPS=1
# מגבלת קצב ל־GET /api/dashboard (מספר בקשות לכל חלון; ברירת מחדל 150 / 60s)
# DASHBOARD_RATE_WINDOW_MS=60000
# DASHBOARD_RATE_MAX=150
# מקס׳ גודל גוף תשובה (bytes), מגן מפני תשובות חריגות
OREF_MAX_RESPONSE_BYTES=2000000

# גיבוי WebSocket לצבע אדום (tzevaadom) — נכנס ל-poll רק כש-OREF נכשל (HTTP/רשת) או שהתשובה אינה JSON תקין. לא API רשמי.
TZOFAR_BACKUP_ENABLED=0
# TZOFAR_WS_URL=wss://ws.tzevaadom.co.il/socket?platform=ANDROID
# TZOFAR_BACKUP_RECONNECT_MS=12000

# OpenSky
OPENSKY_URL=https://opensky-network.org/api/states/all
OPENSKY_TIMEOUT_MS=5000
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# NASA FIRMS (לווייני חום VIIRS — נקודות חום באזור; משלימים הקשר גיאוגרפי, לא מזהים טיל ישירות)
# If FIRMS_API_URL is empty, the server will build a default Middle East area query
# from FIRMS_API_KEY + FIRMS_SOURCE + FIRMS_AREA + FIRMS_DAY_RANGE.
FIRMS_API_KEY=
FIRMS_TIMEOUT_MS=5000
FIRMS_API_URL=
FIRMS_SOURCE=VIIRS_NOAA21_NRT
FIRMS_AREA=32,10,61,38
FIRMS_DAY_RANGE=1

# GDELT
# If GDELT_API_URL is empty, the server will build a default DOC API query
# for the Iran/Israel/Lebanon/Syria/Iraq/Yemen/UAE / Red Sea theatre.
GDELT_API_URL=
GDELT_TIMEOUT_MS=5000
GDELT_QUERY=(iran OR israel OR lebanon OR syria OR iraq OR yemen OR "united arab emirates" OR uae OR "red sea")
GDELT_TIMESPAN=1h
GDELT_MAXRECORDS=50
# במקביל ל־Oref: כמה שאילתות DOC במקביל (0 = שאילתה אחת כמו הפולר). JSON מותאם אישית: מערך מחרוזות query
# GDELT_FUSION_BURST=0
# GDELT_FUSION_BURST_QUERIES_JSON=["(lebanon OR hezbollah) missile","(yemen OR houthi) strike"]

# חדשות: משיכת RSS מהשרת כל X מילישניות (מינימום ~5000), דחיפה לדפדפן ב-Socket
NEWS_FETCH_INTERVAL_MS=45000

# Additional war-news RSS / Atom feeds, comma-separated
NEWS_RSS_TIMEOUT_MS=5000
NEWS_RSS_URLS=https://feeds.bbci.co.uk/news/world/middle_east/rss.xml,https://www.jpost.com/rss/rssfeedsmiddleeastnews.aspx,https://www.jpost.com/rss/rssfeedsiran,https://www.jpost.com/rss/rssfeedsarabisraeliconflict.aspx,https://news.google.com/rss/search?q=Iran+Israel+Lebanon+Syria+Iraq+Yemen&hl=en-US&gl=US&ceid=US:en
# מקורות נוספים כ־JSON: [{"name":"my_feed","url":"https://.../feed.xml","category":"world","allowInsecure":false}]
# NEWS_EXTRA_SOURCES_JSON=

# Optional translation endpoint for turning foreign headlines into Hebrew.
# Example shape: LibreTranslate-compatible /translate endpoint.
TRANSLATE_API_URL=https://translate.argosopentech.com/translate
TRANSLATE_API_KEY=
TRANSLATE_TIMEOUT_MS=6000

# ==========================================
# NEW SOURCES - Iran War Monitor Extended
# ==========================================

# ADS-B Exchange (Free public API at adsb.one)
# Get free access: https://api.adsb.one/
ADSB_EXCHANGE_URL=https://api.adsb.one/v2/point/32/35/500
# נקודות נוספות מופרדות בפסיק — מתמזגות עם OpenSky (כיסוי טוב יותר, כולל טיסות אל על עם קוד ELY)
# ADSB_EXCHANGE_URLS=https://api.adsb.one/v2/point/32.01/34.88/300,https://api.adsb.one/v2/point/31.5/35/400
ADSB_TIMEOUT_MS=5000
# מקסימום מטוסים אחרי מיזוג OpenSky+ADSB (ברירת מחדל 200)
# FLIGHTS_MERGED_MAX=200

# MarineTraffic (Requires API key - free trial available)
# Get API key: https://www.marinetraffic.com/en/p/plans/api-plans
MARINETRAFFIC_API_KEY=
MARINETRAFFIC_URL=
MARINE_MIN_LAT=10
MARINE_MAX_LAT=45
MARINE_MIN_LNG=20
MARINE_MAX_LNG=70
MARINE_TIMESPAN_MIN=20
MARINE_PROTOCOL=jsono
MARINE_TIMEOUT_MS=5000

# כלי שיט (AIS): ללא מפתח — גיבוי ציבורי MyShipTracking; אם VESSELAPI/MarineTraffic נכשלים או AIS_API_URL ריק — עובר אוטומטית לגיבוי
# VESSELAPI_KEY=
# AIS_API_URL=
# SHIP_PUBLIC_URL=
# SHIP_PUBLIC_TIMEOUT_MS=16000
# SHIP_FALLBACK_URLS= (רשימת URL-ים מופרדת בפסיקים, אותו פורמט טקסט כמו MyShip)
# SHIP_PUBLIC_MIN_LAT=29
# SHIP_PUBLIC_MAX_LAT=34.5
# SHIP_PUBLIC_MIN_LNG=32
# SHIP_PUBLIC_MAX_LNG=36.5

# ACLED - Armed Conflict Location & Event Data
# Requires API key - academic/research access
# Get access: https://acleddata.com/acleddatanew/wp-content/uploads/2021/12/ACLED_API_Guide.pdf
ACLED_API_KEY=
ACLED_EMAIL=
ACLED_TIMEOUT_MS=5000

# Twitter/X API v2 (Requires Bearer Token from developer portal)
# Get token: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_TIMEOUT_MS=5000

# Telegram Bot API (Get token from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_TIMEOUT_MS=5000
# ערוצים ציבוריים (t.me/s/...) — נוספים לברירת מחדל פנימית לזיהוי ציר שיגור. כיבוי ברירות מחדל: TELEGRAM_AXIS_DEFAULT_CHANNELS=0
TELEGRAM_PUBLIC_CHANNELS=
# מקס׳ ערוצי טלגרם לסריקת ציר (ברירת מחדל 28)
# TELEGRAM_AXIS_MAX_CHANNELS=28

# OSINT לציר איום (מדינת מוצא משוערת) — משלים לפיקוד. כיבוי מלא: OSINT_AXIS_HINTS=0
# חנות חדשות מהשרת + RSS — כיבוי: OSINT_INCLUDE_NEWS_STORE=0 או OSINT_INCLUDE_RSS=0
# RSS נוספים: OSINT_RSS_URLS=url1,url2  |  בלי פידי ברירת־מחדל של OSINT: OSINT_AXIS_DEFAULT_RSS=0
# OSINT_RSS_URLS=
# OSINT_INCLUDE_JSON_FEED=1
# OSINT_JSON_FEED_URL=

# OpenAI (responses + Telegram missile extraction)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# מנוע חקירת מוצא שיגור (AI) — דורש OPENAI_API_KEY. הפעלה מפורשת:
# LAUNCH_AXIS_AI_ENABLED=1
# לאחר burst OSINT+GDELT עם התרעת פיקוד — הרצת מנוע AI מיידית (כיבוי: LAUNCH_AXIS_AI_ON_OREF_BURST=0)
# LAUNCH_AXIS_AI_ON_OREF_BURST=1
# LAUNCH_AXIS_AI_POLL_MS=14000
# LAUNCH_AXIS_AI_MIN_CONFIDENCE=0.72
# LAUNCH_AXIS_AI_STRONG_CONFIDENCE=0.85
# LAUNCH_AXIS_AI_APPLY_MIN_CONFIDENCE=0.71
# LAUNCH_AXIS_AI_AXIS_CHANGE_MIN=0.77
# LAUNCH_AXIS_AI_LOCK_MIN_CONFIDENCE=0.76
# LAUNCH_AXIS_AI_MIN_EVIDENCE_LINES=1
# LAUNCH_AXIS_AI_SINGLE_EVIDENCE_OK_CONFIDENCE=0.86
# קיבוע מוצא: כמה טיקי AI רצופים + מקור מערכת (OSINT/GDELT/טקסט מפורש פיקוד) לפני עדכון מפה; שינוי אחרי נעילה קשה יותר
# LAUNCH_AXIS_AI_COMMIT_TICKS=2
# LAUNCH_AXIS_AI_INSTANT_COMMIT_CONFIDENCE=0.91
# LAUNCH_AXIS_AI_CORROBORATION_SOURCES=1
# LAUNCH_AXIS_AI_SKIP_CORROB_IF_CONFIDENCE=0.86
# LAUNCH_AXIS_AI_STREAK_ALONE_COMMITS=3
# LAUNCH_AXIS_AI_UNLOCK_TICKS=3
# LAUNCH_AXIS_AI_UNLOCK_MIN_CONFIDENCE=0.88
# LAUNCH_AXIS_AI_OVERRIDE_OFFICIAL=1
# LAUNCH_AXIS_AI_TIMEOUT_MS=55000
# LAUNCH_AXIS_AI_MAX_TOKENS=700

# Telegram + OpenAI: early missile tracks (IWM-style). Requires OPENAI_API_KEY.
# Set to 0 to disable AI-extracted missiles before Oref.
TELEGRAM_MISSILE_AI=1
TELEGRAM_MISSILE_POLL_MS=10000
TELEGRAM_AI_MIN_CONFIDENCE=0.7
TELEGRAM_EARLY_MISSILE_TTL_MS=1500000

# GDELT doc API (set GDELT_ENABLED=0 to disable polling)
GDELT_ENABLED=1
GDELT_POLL_MS=120000

# Prediction markets (Polymarket + Manifold). Set PREDICTION_MARKETS_ENABLED=0 to disable.
PREDICTION_MARKETS_ENABLED=1
PREDICTION_MARKETS_POLL_MS=300000

# Credibility half-life for decay (ms)
CREDIBILITY_HALF_LIFE_MS=300000

# USGS Seismic (Free public API - already configured)
USGS_TIMEOUT_MS=5000
